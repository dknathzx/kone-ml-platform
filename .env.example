# Copy this to .env.local for local development
# Add these as Environment Variables in Vercel dashboard

# Your Databricks workspace URL
REACT_APP_DATABRICKS_HOST=https://dbc-ff69c8c1-012b.cloud.databricks.com

# Your Databricks personal access token
REACT_APP_DATABRICKS_TOKEN=your_token_here

# Your SQL Warehouse ID (from Databricks SQL Warehouses)
REACT_APP_WAREHOUSE_ID=your_warehouse_id_here
